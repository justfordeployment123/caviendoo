# ─────────────────────────────────────────────────────────────────────────────
# Caviendoo API — Environment Variables
# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL 16 + PostGIS) ────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://caviendoo_user:CHANGE_ME@localhost:5432/caviendoo_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Format: redis://HOST:PORT  (add :PASSWORD@ if auth is enabled)
REDIS_URL=redis://127.0.0.1:6379

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_USE_CRYPTO_RANDOM
JWT_EXPIRES_IN=24h

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET=caviendoo-media
# Full CDN base URL (CloudFront or direct S3 URL)
CDN_BASE_URL=https://media.caviendoo.com

# ── Image Providers ───────────────────────────────────────────────────────────
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=CHANGE_ME
# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=CHANGE_ME
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=CHANGE_ME

# ── Environmental APIs ────────────────────────────────────────────────────────
# OpenUV: https://www.openuv.io/
OPENUV_API_KEY=CHANGE_ME
# UV index threshold above which an alert is triggered (default 8 = Very High)
UV_ALERT_THRESHOLD=8

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Used ONLY during initial seed to create the first admin account.
# Remove after first seed run.
ADMIN_INITIAL_EMAIL=admin@caviendoo.com
ADMIN_INITIAL_PASSWORD=CHANGE_ME_STRONG_12_CHARS_MIN
